{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nkhippo/English-Vocab-Chunk-Trainer/schema/v1",
  "title": "Vocab & Chunk Trainer Data Schema",
  "description": "Authoritative schema for LearningItem and Insight. Version 1.2.4 (2026-07-11): dataset content patch for confusables/common_errors role separation (no structural change from 1.2.3). Prior 1.2.3: nuance_contrast_ja; example_en/ja; hypernyms/hyponyms removed. See doc/ops/confusables-common-errors-role-separation.md.",
  "version": "1.2.4",
  "definitions": {
    "cefrLevel": {
      "type": "string",
      "enum": ["A1", "A2", "B1", "B2", "C1", "C2"]
    },
    "category": {
      "type": "string",
      "enum": [
        "word",
        "collocation",
        "phrasal_verb",
        "idiom",
        "binomial",
        "compound",
        "institutionalized",
        "other"
      ]
    },
    "register": {
      "type": "string",
      "enum": ["formal", "neutral", "informal"]
    },
    "skillFocus": {
      "type": "string",
      "enum": ["receptive_only", "receptive_and_productive"]
    },
    "collocationPattern": {
      "type": ["string", "null"],
      "enum": [
        "V+N",
        "Adj+N",
        "Adv+V",
        "Adv+Adj",
        "V+Prep",
        "V+Prep+N",
        "V+Ving",
        "V+Adv",
        "N+of+N",
        null
      ]
    },
    "exampleSentence": {
      "type": "object",
      "required": ["en", "ja", "register", "surrounding_cefr_ceiling"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "ja": { "type": "string", "minLength": 1 },
        "register": { "$ref": "#/definitions/register" },
        "surrounding_cefr_ceiling": { "$ref": "#/definitions/cefrLevel" }
      }
    },
    "synonymEntry": {
      "type": "object",
      "required": ["item", "nuance_contrast_ja"],
      "properties": {
        "item": { "type": "string" },
        "nuance_contrast_ja": {
          "type": "string",
          "description": "対象語との対比を明示する説明"
        },
        "example_en": {
          "type": "string",
          "description": "この類義語自体を使った例文(英語)"
        },
        "example_ja": {
          "type": "string",
          "description": "example_en の日本語訳"
        }
      }
    },
    "antonymEntry": {
      "type": "object",
      "required": ["item", "nuance_contrast_ja"],
      "properties": {
        "item": { "type": "string" },
        "nuance_contrast_ja": {
          "type": "string",
          "description": "対象語との対比を明示する説明"
        },
        "example_en": {
          "type": "string",
          "description": "この反意語自体を使った例文(英語)"
        },
        "example_ja": {
          "type": "string",
          "description": "example_en の日本語訳"
        }
      }
    },
    "confusableEntry": {
      "type": "object",
      "required": ["item", "similarity_ja", "key_difference_ja"],
      "properties": {
        "item": { "type": "string" },
        "similarity_ja": { "type": "string" },
        "key_difference_ja": { "type": "string" },
        "correct_usage_ja": { "type": "string" },
        "example_en": { "type": "string" }
      }
    },
    "relatedUseEntry": {
      "type": "object",
      "required": ["form", "meaning_ja", "type"],
      "properties": {
        "form": { "type": "string" },
        "meaning_ja": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["phrasal_verb", "metaphor", "collocation", "compound", "other"]
        },
        "metaphor_ja": { "type": "string" },
        "example_en": { "type": "string" },
        "example_ja": { "type": "string" }
      }
    },
    "commonError": {
      "type": "object",
      "required": ["incorrect", "correct", "why_ja"],
      "properties": {
        "incorrect": { "type": "string" },
        "correct": { "type": "string" },
        "why_ja": { "type": "string" }
      }
    },
    "srsState": {
      "type": "object",
      "properties": {
        "ease_factor": { "type": "number", "minimum": 1.3 },
        "next_review_at": { "type": "string", "format": "date-time" },
        "correct_streak": { "type": "integer", "minimum": 0 },
        "last_reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "bookAlignment": {
      "type": "object",
      "properties": {
        "basic_2400_units": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "daily_1500_units": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "textSpan": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 }
      }
    },
    "clozeSpan": {
      "type": "object",
      "required": ["start", "end", "answer"],
      "properties": {
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 },
        "answer": { "type": "string", "minLength": 1 }
      }
    },
    "context": {
      "type": "object",
      "required": ["id", "text_en", "text_ja", "target_span", "cloze_spans"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+_c[1-5]$",
          "description": "e.g., make_a_decision_c1"
        },
        "text_en": {
          "type": "string",
          "minLength": 20,
          "description": "English passage, 1-3 sentences, containing the target chunk exactly once"
        },
        "text_ja": {
          "type": "string",
          "minLength": 10,
          "description": "Natural Japanese translation of the entire passage"
        },
        "target_span": {
          "$ref": "#/definitions/textSpan",
          "description": "Character position of the target chunk in text_en (used for Mode A highlight)"
        },
        "cloze_spans": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/definitions/clozeSpan" },
          "description": "Positions in text_en to blank out for Mode B. answer is the original text at that span."
        },
        "scene": {
          "type": "string",
          "description": "Optional scene tag for diversity tracking, e.g., 'business_meeting', 'family_conversation'"
        },
        "register": {
          "$ref": "#/definitions/register",
          "description": "Optional register of this specific passage"
        }
      }
    },
    "learningItem": {
      "type": "object",
      "required": [
        "id",
        "surface",
        "category",
        "cefr_level",
        "frequency_rank_in_level",
        "translations_ja",
        "example_sentences",
        "semantic_field",
        "register",
        "skill_focus",
        "ipa_careful"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "snake_case unique identifier"
        },
        "surface": {
          "type": "string",
          "description": "The learning item as displayed"
        },
        "category": { "$ref": "#/definitions/category" },
        "cefr_level": { "$ref": "#/definitions/cefrLevel" },
        "frequency_rank_in_level": {
          "type": "integer",
          "minimum": 1,
          "description": "Rank within its CEFR level; lower = more frequent"
        },
        "translations_ja": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "definition_en": { "type": "string" },
        "example_sentences": {
          "type": "array",
          "items": { "$ref": "#/definitions/exampleSentence" },
          "minItems": 1,
          "maxItems": 5,
          "description": "Minimum 1, target 3 across register variants; register set depends on item"
        },
        "semantic_field": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "register": {
          "type": "array",
          "items": { "$ref": "#/definitions/register" },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Set of registers this item can naturally be used in. Derived from example_sentences[].register in the pipeline; used for browse-view filtering."
        },
        "collocation_pattern": { "$ref": "#/definitions/collocationPattern" },
        "function_tag": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Only for institutionalized expressions; e.g., ['greeting', 'conversation_opener']"
        },
        "skill_focus": { "$ref": "#/definitions/skillFocus" },
        "ipa_careful": { "type": "string" },
        "ipa_connected": {
          "type": "string",
          "description": "Connected/linking IPA for phrases. Retained in data; current UI may show ipa_careful only (v7/v8). Single-word items may omit this."
        },
        "audio_ref": { "type": "string" },
        "book_alignment": { "$ref": "#/definitions/bookAlignment" },
        "insight_id": { "type": ["string", "null"] },
        "synonyms": {
          "type": "array",
          "items": { "$ref": "#/definitions/synonymEntry" },
          "maxItems": 5
        },
        "antonyms": {
          "type": "array",
          "items": { "$ref": "#/definitions/antonymEntry" },
          "maxItems": 5
        },
        "confusables": {
          "type": "array",
          "items": { "$ref": "#/definitions/confusableEntry" },
          "maxItems": 5
        },
        "related_uses": {
          "type": "array",
          "items": { "$ref": "#/definitions/relatedUseEntry" },
          "maxItems": 8
        },
        "common_errors_ja": {
          "type": "array",
          "items": { "$ref": "#/definitions/commonError" },
          "maxItems": 5
        },
        "contexts": {
          "type": "array",
          "items": { "$ref": "#/definitions/context" },
          "minItems": 5,
          "maxItems": 5,
          "description": "Passages for Mode A (read+highlight) and Mode B (cloze). Exactly 5 when present. Omit for word-category items (excluded from Mode A/B)."
        },
        "srs_state": {
          "$ref": "#/definitions/srsState",
          "description": "Reserved for Phase 2+ SRS. Not populated in current pilot data; learning-history checkmarks use localStorage instead."
        },
        "meta": {
          "type": "object",
          "properties": {
            "schema_version": { "type": "string" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" },
            "validated_by_user": { "type": "boolean" },
            "source": {
              "type": "string",
              "enum": ["ngsl", "nawl", "phave", "afl", "evp_ref", "claude_generated"]
            }
          }
        }
      }
    },
    "insight": {
      "type": "object",
      "required": ["id", "target_id", "type", "content_ja"],
      "properties": {
        "id": { "type": "string", "pattern": "^insight_[a-z0-9_]+$" },
        "target_id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["morphology", "metaphor", "cultural", "cognate", "core_image"]
        },
        "content_ja": { "type": "string", "minLength": 1 },
        "content_en": { "type": "string" },
        "related_items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "claude_generated": { "type": "boolean" },
        "validated_at": { "type": "string", "format": "date-time" }
      }
    },
    "dataset": {
      "type": "object",
      "required": ["schema_version", "items"],
      "properties": {
        "schema_version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "cefr_levels_included": {
          "type": "array",
          "items": { "$ref": "#/definitions/cefrLevel" }
        },
        "total_items": { "type": "integer" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/learningItem" }
        },
        "insights": {
          "type": "array",
          "items": { "$ref": "#/definitions/insight" }
        }
      }
    }
  },
  "$ref": "#/definitions/dataset"
}
